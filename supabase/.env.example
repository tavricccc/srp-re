# Supabase Edge Functions 本機開發環境變數
# 複製此檔為 .env 並填入實際值（本機執行 supabase functions serve 時使用）
# 正式部署由 deploy-backend.yml 透過 supabase secrets set 自動寫入

# Supabase（本機由 CLI 自動注入；正式環境由 Supabase 平台提供）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Firebase（Firebase Console → 專案設定）
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=

# Google / Firebase Service Account（Firebase Console → 專案設定 → Service Accounts → 產生金鑰，完整 JSON 內容）
GOOGLE_SERVICE_ACCOUNT_JSON=

# 校園 email domain（不帶 VITE_ 前綴，為後端驗證用）
ALLOWED_DOMAIN=mail.yourschool.edu

# Cloudinary（Cloudinary Dashboard → Settings）
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_WEBHOOK_SECRET=

# Notion（Notion → Settings → Connections → Develop or manage integrations）
NOTION_TOKEN=
NOTION_VERSION=2022-06-28

# Upstash Redis（Upstash Console → 選取 Redis 資料庫 → REST API）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Webhook 驗證金鑰（自訂隨機字串）
WEBHOOK_SECRET=
