# Novae environment-variable checklist
# Copy this file to .env only for local frontend development. Never commit real values.
# For deployment, add the same names as GitHub Environment secrets under
# production (main) or development (dev). See the official deployment guide:
# https://tavricccc.github.io/novae-website/docs/deployment-guide.html

# Browser-visible frontend values (VITE_* values are not private)
VITE_SCHOOL_NAME=你的學校名稱
VITE_ALLOWED_DOMAIN=school.edu.tw
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_VAPID_KEY=
VITE_FIREBASE_APP_CHECK_ENABLED=false
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Firebase backend secrets
# FIREBASE_PROJECT_ID is normally the same value as VITE_FIREBASE_PROJECT_ID.
# FIREBASE_WEB_API_KEY is normally the same value as VITE_FIREBASE_API_KEY.
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Vercel deployment credentials
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Supabase CLI deployment credentials
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase hosted Edge Functions provide SUPABASE_URL automatically.
# Do not create a GitHub secret for it. It is listed here only for manual hosting.
SUPABASE_URL=

# Application access control
# Use a domain only (no @ or https://). ADMIN_EMAILS only bootstraps the first
# platform-admin when no role assignment exists; later access is managed by RBAC.
ALLOWED_DOMAIN=school.edu.tw
ADMIN_EMAILS=admin@school.edu.tw

# Cloudinary image processing
# For the standard Cloudinary HMAC webhook, use the API secret again as
# CLOUDINARY_WEBHOOK_SECRET; do not invent an unrelated random value.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_WEBHOOK_SECRET=

# Internal healthcheck/worker secret. Generate an independent random value.
WEBHOOK_SECRET=

# Optional Notion operational copy. 提案與設備共用同一個 Database；不要另設設備 Database。
# Leave all three values empty to disable it.
# If enabled, NOTION_TOKEN and NOTION_DATABASE_ID must both be set.
# GitHub deployment derives NOTION_ENABLED automatically; this flag is for local/manual hosting.
NOTION_ENABLED=false
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28

# Upstash Redis rate limiting (use the Standard REST token, not Read-only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
