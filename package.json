{
  "name": "novae",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "generate:api-errors": "node scripts/generate-api-errors.mjs",
    "generate:rate-limits": "node scripts/generate-rate-limits.mjs",
    "generate:data-retention": "node scripts/generate-data-retention.mjs",
    "generate:backend-actions": "node scripts/generate-backend-actions.mjs",
    "generate:all": "npm run generate:api-errors && npm run generate:rate-limits && npm run generate:data-retention && npm run generate:backend-actions",
    "pretypecheck": "npm run generate:all",
    "prelint": "npm run generate:all",
    "prebuild": "npm run generate:all",
    "build": "vue-tsc -b && vite build",
    "build:deploy": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "check:edge": "deno check --no-lock supabase/functions/outboxWorker/index.ts supabase/functions/backendAction/index.ts supabase/functions/syncUser/index.ts supabase/functions/cloudinaryWebhook/index.ts supabase/functions/processDeletionJobs/index.ts supabase/functions/maintenanceCleanup/index.ts",
    "check:worker": "tsc -p cloudflare/tsconfig.json --noEmit",
    "check:unused": "vue-tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:ui": "node scripts/check-ui-primitives.mjs",
    "verify:local": "npm run typecheck && npm run check:unused && npm run check:i18n && npm run check:ui && npm run lint && npm run build && npm run check:worker && npm run check:edge && npm run test:architecture && npm audit --offline --omit=dev",
    "verify:integration": "node scripts/verify-integration-local.mjs",
    "verify:stress": "node scripts/verify-integration-local.mjs --stress-scale 8",
    "test:env": "node scripts/verify-integration-local.mjs --serve",
    "verify:all": "npm run verify:local && npm run verify:integration",
    "test:architecture": "node --test tests/architecture.test.mjs",
    "test": "npm run test:architecture",
    "db:start": "supabase start",
    "db:reset:local": "supabase db reset --local",
    "db:lint:local": "supabase db lint --local"
  },
  "dependencies": {
    "@jsquash/webp": "1.5.0",
    "@lucide/vue": "^1.24.0",
    "@supabase/postgrest-js": "2.110.7",
    "@supabase/supabase-js": "2.110.7",
    "dompurify": "3.4.12",
    "firebase": "12.16.0",
    "harmonyos-sans-webfont-splitted": "^1.2.1",
    "jose": "^6.1.3",
    "marked": "18.0.6",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "24.13.3",
    "@typescript-eslint/parser": "8.63.0",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/tsconfig": "0.9.1",
    "deno-bin": "^2.2.7",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "google-auth-library": "^10.9.0",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vue-tsc": "3.3.7"
  }
}
