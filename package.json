{
  "name": "novae",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:issue-categories": "node scripts/generate-issue-categories.mjs",
    "generate:rate-limits": "node scripts/generate-rate-limits.mjs",
    "generate:all": "npm run generate:issue-categories && npm run generate:rate-limits",
    "pretypecheck": "npm run generate:all",
    "prelint": "npm run generate:all",
    "prebuild": "npm run generate:all",
    "build": "vue-tsc -b && vite build",
    "build:deploy": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "check:edge": "deno check supabase/functions/outboxWorker/index.ts supabase/functions/backendAction/index.ts supabase/functions/syncUser/index.ts supabase/functions/cloudinaryWebhook/index.ts supabase/functions/processDeletionJobs/index.ts supabase/functions/maintenanceCleanup/index.ts",
    "check:unused": "vue-tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "verify:local": "npm run typecheck && npm run check:unused && npm run lint && npm run build && npm run check:edge && npm run test:architecture && npm audit --offline --omit=dev",
    "test:architecture": "node --test tests/architecture.test.mjs",
    "test": "npm run test:architecture",
    "db:start": "supabase start",
    "db:reset:local": "supabase db reset --local",
    "db:lint:local": "supabase db lint --local"
  },
  "dependencies": {
    "@jsquash/webp": "1.5.0",
    "@supabase/supabase-js": "^2.110.0",
    "dompurify": "3.4.11",
    "firebase": "12.14.0",
    "jose": "^6.1.3",
    "marked": "18.0.5",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.20",
    "@types/node": "24.13.1",
    "@typescript-eslint/parser": "8.61.0",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "deno-bin": "^2.2.7",
    "eslint": "10.4.1",
    "eslint-plugin-vue": "10.9.2",
    "google-auth-library": "^10.9.0",
    "postcss": "8.5.15",
    "supabase": "2.109.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "vue-tsc": "3.3.4"
  }
}
